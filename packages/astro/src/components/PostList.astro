---
import type { Post } from '../types.ts'

interface Props {
  posts: Post[]
  animateDelay?: boolean
}

const { posts, animateDelay = false } = Astro.props

function readingTime(wordCount: number): string {
  const minutes = Math.max(1, Math.round(wordCount / 400))
  return `${minutes} min`
}
---

<ul class="post-list">
  {posts.map((post, i) => (
    <li style={animateDelay ? `animation-delay: ${i * 0.05}s` : undefined}>
      <a href={post.url} class="post-list-title">{post.title}</a>
      <div class="post-meta">
        {post.date}
        {post.tags.length > 0 && <span> &middot; {post.tags.join(', ')}</span>}
        {post.wordCount != null && post.wordCount > 0 && (
          <span> &middot; {post.wordCount} 字 &middot; {readingTime(post.wordCount)}</span>
        )}
      </div>
    </li>
  ))}
</ul>

<style is:global>
  .post-list li {
    animation: fadeInUp 0.45s var(--ease-out) both;
  }
</style>
