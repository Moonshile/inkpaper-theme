---
import BaseLayout from '../components/BaseLayout.astro'
import TagsPage from '../components/TagsPage.astro'
import { getSortedPosts } from '../utils/posts.ts'
import { getSidebarItems } from '../utils/sidebar.ts'
import config from 'virtual:inkpaper-config'

const posts = await getSortedPosts(config.postsBase)
const sidebarItems = await getSidebarItems('tags', config.sidebar, config.postsBase)
---

<BaseLayout title={config.title} description={config.description} pageTitle="Tags" nav={config.nav} sidebarItems={sidebarItems} currentPath={Astro.url.pathname}>
  <TagsPage posts={posts} />
</BaseLayout>
